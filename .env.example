# ap-server
server_listen_address=0.0.0.0:8080
database_url=postgresql://user:password@host:5432/postgres

# ap-assistant
claude_api_key=
claude_chat_model=claude-haiku-4-5
claude_voice_model=claude-haiku-4-5
claude_chat_max_tokens=1024
claude_voice_max_tokens=512
# Max conversation messages retained per session; older ones are trimmed.
max_message_history=30
redis_url=redis://localhost:6379
# redis spawn command; defaults to redis-server (a Docker container on Windows)
# redis_cmd=redis-server

# ap-civic
find_my_rep_gis_url=https://services.arcgis.com/g1fRTDLeMgspWrYp/arcgis/rest/services/CouncilDistricts/FeatureServer/2
geocode_url=https://geocode.arcgis.com/arcgis/rest/services/World/GeocodeServer
my_area_police_url=https://services.arcgis.com/g1fRTDLeMgspWrYp/arcgis/rest/services/SAPD_Service_Areas/FeatureServer/0
my_area_fire_url=https://services.arcgis.com/g1fRTDLeMgspWrYp/arcgis/rest/services/SAFD_Areas_Of_Responsibility/FeatureServer/0
my_area_neighborhood_url=https://services.arcgis.com/g1fRTDLeMgspWrYp/arcgis/rest/services/Neighborhood_Associations/FeatureServer/9
council_staff_source_url=https://www.sa.gov/Directory/Departments/Mayor-Council/About/Staff
collection_schedule_source_url=https://gis.sanantonio.gov/swmd/mycollectionday/Request.aspx
city_alerts_source_url=https://sat.ahasalerts.com/activealerts.aspx
nws_alerts_api_url=https://api.weather.gov/alerts/active?zone=TXC029
city_events_source_url=https://www.sanantonio.gov/comm/CityEvents
# days
alerts_retention_days=30
# days
events_retention_days=30
# days
collection_schedule_refresh_days=30
# days
find_my_rep_refresh_days=180

# ap-utility
# days
utility_retention_days=30
power_outage_source_url=https://kubra.io/stormcenter/api/v1/stormcenters/912c6202-c3f4-491c-a8c1-726157725e92/views/812092c0-153f-4a7f-8c58-e1af1cb740b7/currentState?preview=false
# days
bill_due_reminder_days=5

# ap-notifications
notification_pending_ttl_minutes=1440

# ap-server (crawl4ai sidecar)
crawl_service_url=http://127.0.0.1:8095

# ap-voice
# milliseconds
filler_delay_ms=1500
deepgram_api_key=
elevenlabs_api_key=
# fallback voice when the client sends none
elevenlabs_voice_id=7EzWGsX10sAS4c9m9cPf
stt_encoding=linear16
# Hz
stt_sample_rate=16000
enable_barge_in=true
# minimum interim transcript length (chars) that counts as a real barge-in
barge_in_min_chars=2

# ap-server (scheduler)
# city the scheduler runs as
CIVIC_SCHEDULER_CITY_TENANT_ID=san-antonio
# minutes
scheduler_collection_schedule_interval_minutes=4320
# minutes
scheduler_city_alerts_interval_minutes=5
# minutes
scheduler_city_events_interval_minutes=1440
# minutes
scheduler_power_outage_interval_minutes=5
# minutes
scheduler_bill_reminder_interval_minutes=1440
